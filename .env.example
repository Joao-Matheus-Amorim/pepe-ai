# Configurações do Pepê
PEPE_NAME=Pepê
PEPE_USER_NAME=Seu Nome
PEPE_VOICE_ENABLED=true
PEPE_MEMORY_PATH=./memory/data
PEPE_MODEL_PROVIDER=ollama
PEPE_OLLAMA_MODEL=llama3.1
PEPE_PERPLEXITY_MODEL=sonar-reasoning
PEPE_GROQ_MODEL=llama-3.1-70b-versatile
PEPE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
PEPE_SEARCH_PROVIDER=ddgs
PEPE_SEARCH_FALLBACK_DDGS=true
PEPE_PERPLEXITY_PROFILE_DIR=./memory/perplexity-profile
PEPE_PERPLEXITY_HEADLESS=true
PEPE_PERPLEXITY_BROWSER_CHANNEL=chrome
PEPE_PERPLEXITY_LOGIN_METHOD=manual
# Opções: manual | google | email

# API Configuration
PEPE_API_KEY=sua-chave-secreta-aqui-mudanca-obrigatoria
PEPE_API_PORT=8000
PEPE_API_HOST=0.0.0.0

# API Keys
PERPLEXITY_API_KEY=sua_chave_perplexity_aqui
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
GROQ_API_KEY=sua_chave_groq_aqui
PEPE_PERPLEXITY_EMAIL=seu_email_aqui
PEPE_PERPLEXITY_PASSWORD=sua_senha_aqui

# LangSmith (opcional)
LANGCHAIN_API_KEY=sua_chave_langsmith_aqui
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=pepe-ai
